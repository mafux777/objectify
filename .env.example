# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
VITE_OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Set to "true" to bypass auth for local development (never use in production)
# VITE_AUTH_BYPASS=true

# Safe wallet: public address of the master EOA that owns all user Safes
# MASTER_SAFE_OWNER_ADDRESS=0xYourAddressHere

# Base RPC URL (optional, defaults to https://mainnet.base.org)
# BASE_RPC_URL=https://mainnet.base.org

# Supabase service role key (for CLI scripts that need admin DB access)
# Get from: supabase dashboard → Settings → API → service_role key
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
