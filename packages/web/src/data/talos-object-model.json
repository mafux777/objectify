          ]
        },
        {
          "id": "user",
          "label": "User",
          "type": "box",
          "shapeId": "entity",
          "semanticTypeId": "identity-entity",
          "description": "A person with access to the Talos platform. Stored in the central AVA database and assigned one or more roles that control which operations they can perform.",
          "style": { "backgroundColor": "#E3F2FD", "textColor": "#1565C0", "borderColor": "#90CAF9" },
          "guideRow": "r2", "guideColumn": "c1",
          "orderHint": 2,
          "labels": [
            { "text": "User", "position": "center" },
            { "text": "users · AVA", "position": "6:00", "font": { "fontSize": 10, "fontFamily": "monospace" } }
          ]
        },
        {
          "id": "role",
          "label": "Role",
          "type": "box",
          "shapeId": "entity",
          "semanticTypeId": "identity-entity",
          "description": "A named permission set assigned to a User. Controls which API operations and resources that user can access across the platform.",
          "style": { "backgroundColor": "#E3F2FD", "textColor": "#1565C0", "borderColor": "#90CAF9" },
          "guideRow": "r3", "guideColumn": "c1",
          "orderHint": 3,
