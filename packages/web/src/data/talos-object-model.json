          ]
        },
        {
          "id": "credential",
          "label": "Credential",
          "type": "box",
          "shapeId": "entity",
          "semanticTypeId": "market-entity",
          "description": "Exchange API credentials (key + secret) for a specific broker or venue. Stored per-org and used to authenticate outbound gateway connections to a Market.",
          "style": { "backgroundColor": "#E0F2F1", "textColor": "#004D40", "borderColor": "#80CBC4" },
          "guideRow": "r2", "guideColumn": "c4",
          "orderHint": 5,
