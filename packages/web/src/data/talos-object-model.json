          "type": "box",
          "shapeId": "assoc",
          "semanticTypeId": "access-entity",
          "description": "Restricts an API Key to a subset of SubAccounts. Acts as a join-table constraint so that a key can only route orders to the SubAccounts explicitly granted to it.",
          "style": { "backgroundColor": "#F3E5F5", "textColor": "#4A148C", "borderColor": "#CE93D8", "borderStyle": "dashed" },
          "guideRow": "r3", "guideColumn": "c3",
