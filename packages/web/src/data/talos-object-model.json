{
  "version": "8.0",
  "description": "Talos trading platform object model for a single organization tenant. Visualizes the key entities and relationships across four domains: Identity & Access (User, Role, API Key — all in AVA DB), Market Connectivity (Market in AVA DB; Credential, Market Account, Market Connection in OrgDB), Account Management (SubAccount, Permission Filter, User Credential — OrgDB), and Trading (Configuration, Customer Order, Hedge Order, Customer — OrgDB). Orders link SubAccounts (for internal bookkeeping) to Market Accounts (for exchange execution). The sell-side variant adds Customers for dealer/market-maker workflows. Table names are shown for entities where the DB schema was confirmed in runbooks.",
  "palette": [
    { "id": "platform-bg",   "hex": "#ECEFF1", "percentage": 15, "name": "Platform Light Grey" },
    { "id": "identity-bg",   "hex": "#E3F2FD", "percentage": 12, "name": "Identity Light Blue" },
    { "id": "market-bg",     "hex": "#E0F2F1", "percentage": 12, "name": "Market Light Teal" },
    { "id": "access-bg",     "hex": "#F3E5F5", "percentage": 10, "name": "Access Light Purple" },
    { "id": "trading-bg",    "hex": "#FFF3E0", "percentage": 10, "name": "Trading Light Amber" },
    { "id": "platform-text", "hex": "#37474F", "percentage": 5,  "name": "Platform Dark Blue-Grey" },
    { "id": "identity-text", "hex": "#1565C0", "percentage": 5,  "name": "Identity Deep Blue" },
    { "id": "market-text",   "hex": "#004D40", "percentage": 5,  "name": "Market Deep Teal" },
    { "id": "access-text",   "hex": "#4A148C", "percentage": 5,  "name": "Access Deep Purple" },
    { "id": "trading-text",  "hex": "#BF360C", "percentage": 5,  "name": "Trading Deep Orange" },
    { "id": "border-plat",   "hex": "#90A4AE", "percentage": 3,  "name": "Platform Border" },
    { "id": "border-id",     "hex": "#90CAF9", "percentage": 3,  "name": "Identity Border" },
    { "id": "border-mkt",    "hex": "#80CBC4", "percentage": 3,  "name": "Market Border" },
    { "id": "border-acc",    "hex": "#CE93D8", "percentage": 3,  "name": "Access Border" },
    { "id": "border-trd",    "hex": "#FFCC80", "percentage": 3,  "name": "Trading Border" },
    { "id": "edge-grey",     "hex": "#546E7A", "percentage": 2,  "name": "Edge Grey" },
