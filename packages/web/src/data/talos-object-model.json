          ]
        },
        {
          "id": "market-account",
          "label": "Market Account",
          "type": "box",
          "shapeId": "entity",
          "semanticTypeId": "market-entity",
          "description": "A trading account on a specific exchange, formed by pairing a Credential with a Market. Hedge Orders are routed through a Market Account for execution.",
          "style": { "backgroundColor": "#E0F2F1", "textColor": "#004D40", "borderColor": "#80CBC4" },
          "guideRow": "r3", "guideColumn": "c4",
          "orderHint": 6,
          "labels": [
            { "text": "Market Account", "position": "center" },
            { "text": "market_accounts · OrgDB", "position": "6:00", "font": { "fontSize": 10, "fontFamily": "monospace" } }
          ]
        },
        {
          "id": "market-connection",
          "label": "Market Connection",
          "type": "box",
          "shapeId": "entity",
          "semanticTypeId": "market-entity",
          "description": "A live gateway session for a Credential — the active TCP/WebSocket link to an exchange feed or order router. One Credential can have multiple concurrent connections.",
          "style": { "backgroundColor": "#E0F2F1", "textColor": "#004D40", "borderColor": "#80CBC4" },
          "guideRow": "r4", "guideColumn": "c4",
          "orderHint": 7,
          "labels": [
            { "text": "Market Connection", "position": "center" },
            { "text": "market_connections · OrgDB", "position": "6:00", "font": { "fontSize": 10, "fontFamily": "monospace" } }
          ]
        },
