            { "text": "user_credentials · OrgDB", "position": "6:00", "font": { "fontSize": 10, "fontFamily": "monospace" } }
          ]
        },
        {
          "id": "configuration",
          "label": "Configuration",
          "type": "box",
          "shapeId": "entity",
          "semanticTypeId": "trading-entity",
          "description": "A named set of strategy and risk parameters attached to an org or SubAccount. Governs the behavior of automated trading logic and pre-trade checks.",
