    { "id": "identity-entity", "name": "Identity & Access",     "description": "User identity, role assignments, and machine credentials (AVA DB)" },
    { "id": "market-entity",   "name": "Market Connectivity",   "description": "Exchange and dealer integration: credentials, routing, live connections" },
    { "id": "access-entity",   "name": "Account Management",    "description": "SubAccount access control and user-to-credential linking (OrgDB)" },
    { "id": "trading-entity",  "name": "Trading",               "description": "Order lifecycle, configuration, and sell-side customer objects (OrgDB)" }
