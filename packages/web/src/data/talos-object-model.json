          "id": "customer-order",
          "label": "Customer Order",
          "type": "box",
          "shapeId": "entity",
          "semanticTypeId": "trading-entity",
          "description": "An inbound order from a buy-side client or internal algo. Booked to a SubAccount for P&L tracking and spawns a corresponding Hedge Order for exchange execution.",
