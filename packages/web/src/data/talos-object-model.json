      "id": "talos-object-model",
      "title": "Talos Platform — Object Model",
      "direction": "DOWN",
      "layoutMode": "auto",
      "nodes": [
        {
          "id": "ava-db",
          "label": "AVA Database",
          "type": "group",
          "zLevel": "background",
          "description": "The central Talos database shared across all tenants. Stores platform-wide reference data: users, roles, API keys, and the global list of supported markets.",
          "style": { "backgroundColor": "#BBDEFB", "textColor": "#1565C0", "borderColor": "#64B5F6", "borderStyle": "dashed" },
          "guideRow": "ava_top", "guideColumn": "ava_left", "guideRowBottom": "ava_bot", "guideColumnRight": "c1r",
          "labelPosition": "top-left"
        },
        {
          "id": "org-db",
          "label": "Org Database",
          "type": "group",
          "zLevel": "background",
          "description": "A per-tenant database isolated to a single organization. Contains all account management, market connectivity, and trading state for one org.",
          "style": { "backgroundColor": "#C8E6C9", "textColor": "#2E7D32", "borderColor": "#66BB6A", "borderStyle": "dashed" },
          "guideRow": "org_top", "guideColumn": "org_left", "guideRowBottom": "org_bot", "guideColumnRight": "org_right",
          "labelPosition": "top-left"
        },
        {
