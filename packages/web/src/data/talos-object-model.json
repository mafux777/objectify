            { "text": "Market Security Mode", "position": "center" },
            { "text": "market_security_modes · OrgDB", "position": "6:00", "font": { "fontSize": 10, "fontFamily": "monospace" } }
          ]
        },
        {
          "id": "hedge-order",
          "label": "Hedge Order",
          "type": "box",
          "shapeId": "entity",
          "semanticTypeId": "trading-entity",
          "description": "An outbound order sent to an exchange to hedge or fill a Customer Order. Routed through a Market Account and gated by the Market Security Mode for that instrument.",
