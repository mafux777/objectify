          "label": "SubAccount",
          "type": "box",
          "shapeId": "entity",
          "semanticTypeId": "access-entity",
          "description": "An internal bookkeeping account within the org. Customer Orders are booked to a SubAccount to track position and P&L independently from the exchange execution account.",
