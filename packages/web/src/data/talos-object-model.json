          "label": "Market",
          "type": "box",
          "shapeId": "entity",
          "semanticTypeId": "market-entity",
          "description": "A tradeable venue/exchange (e.g. Kraken, Coinbase). Stored in AVA DB as shared platform reference data. market_id from this table is used as an implicit FK by market_security_modes and credentials in OrgDB — these cross-DB references are enforced by application logic, not SQL constraints.",
          "style": { "backgroundColor": "#E0F2F1", "textColor": "#004D40", "borderColor": "#80CBC4" },
          "guideRow": "r1", "guideColumn": "c1",
          "orderHint": 1,
