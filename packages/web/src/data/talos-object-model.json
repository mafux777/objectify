          ]
        },
        {
          "id": "api-key",
          "label": "API Key",
          "type": "box",
          "shapeId": "entity",
          "semanticTypeId": "identity-entity",
          "description": "A machine credential used by bots, scripts, or client applications. Belongs to a User and inherits that user's roles; can be further restricted by Permission Filters.",
          "style": { "backgroundColor": "#E3F2FD", "textColor": "#1565C0", "borderColor": "#90CAF9" },
          "guideRow": "r4", "guideColumn": "c1",
          "orderHint": 4,
